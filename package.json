{
  "name": "uno-flip",
  "version": "1.0.0",
  "description": "Web-based UNO Flip game for 2-6 players",
  "main": "server/app.js",
  "scripts": {
    "start": "npm run build:assets && NODE_ENV=production node server/app.js",
    "dev": "nodemon server/app.js",
    "build:assets": "esbuild public/js/index.js --bundle --minify --sourcemap --outfile=public/js/bundle.js",
    "build": "npm run build:assets",
    "server": "node server/app.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "esbuild": "^0.21.5"
  },
  "keywords": ["uno", "multiplayer", "game", "socket.io"],
  "author": "My Name",
  "license": "MIT"
}

